# ============================================================
# MDink for Digital Solutions — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم من مشروع Supabase الخاص بك
# Copy this file to .env and fill values from your Supabase project
# ============================================================
# ----- Frontend (آمن للمتصفح / safe for browser) -----
# ----- Frontend (آمن للمتصفح / safe for browser) -----

# ----- Frontend (آمن للمتصفح / safe for browser) -----
# من Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_OR_PUBLISHABLE_KEY"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_OR_PUBLISHABLE_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"

# ----- Server only (للسيرفر فقط — لا تضعه في المتصفح أبدًا) -----
# يُستخدم في Server Functions و Edge Functions فقط
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"
SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_OR_PUBLISHABLE_KEY"

# مفتاح الخدمة السري — NEVER expose to the client
# من Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY_HERE"
